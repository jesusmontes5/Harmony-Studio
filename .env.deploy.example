# Backend - Azure Database for MySQL Flexible Server
DB_URL=jdbc:mysql://your-server.mysql.database.azure.com:3306/tfg_barberia?useUnicode=true&serverTimezone=UTC&useSSL=true
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password

# Backend - security and integrations
JWT_SECRET=replace-with-base64-secret
JWT_EXPIRATION_MINUTES=15
GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
APP_CORS_ALLOWED_ORIGINS=https://your-vercel-domain.vercel.app,http://your-vm-ip-or-domain

# Backend - email notifications
APP_NOTIFICATIONS_EMAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# Frontend - values embedded at build time
VITE_API_TIMEOUT_MS=15000
VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
VITE_HOME_FEATURED_BARBER_ID=2
VITE_CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud
VITE_CLOUDINARY_UPLOAD_PRESET=replace-with-upload-preset
